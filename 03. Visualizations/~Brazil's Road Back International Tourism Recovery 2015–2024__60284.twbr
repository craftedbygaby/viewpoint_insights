          <datasource-dependencies datasource='federated.1qiaabk0wg6l7f12thlb71bzxsqs'>
            <column caption='Brasil_Min_Arrivals' datatype='integer' name='[Calculation_4142690389950482]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([arrivals]) = WINDOW_MIN(SUM([arrivals])) &#13;&#10;THEN SUM([arrivals])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Brasil_Begg_End' datatype='integer' name='[Calculation_4142690390867987]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF FIRST() = 0 &#13;&#10;OR LAST() = 0&#13;&#10;THEN SUM([arrivals])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
