      <aliases enabled='yes' />
      <column caption='Peak/Lowest' datatype='string' name='[Calculation_4142690374709260]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([arrivals]) = WINDOW_MAX(SUM([arrivals])) THEN &quot;🔺 Peak&quot;&#13;&#10;ELSEIF SUM([arrivals]) = WINDOW_MIN(SUM([arrivals])) THEN &quot;🔻 Lowest&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Brasil_Min_Arrivals' datatype='integer' name='[Calculation_4142690389950482]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([arrivals]) = WINDOW_MIN(SUM([arrivals])) &#13;&#10;THEN SUM([arrivals])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Brasil_Begg_End' datatype='integer' name='[Calculation_4142690390867987]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF FIRST() = 0 &#13;&#10;OR LAST() = 0&#13;&#10;THEN SUM([arrivals])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='UNWTO_min' datatype='integer' name='[Calculation_4142690391375892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([arrivals (unwto_processed.csv)]) = WINDOW_MIN(SUM([arrivals (unwto_processed.csv)])) &#13;&#10;THEN SUM([arrivals (unwto_processed.csv)])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='UNWTO_Begg_End' datatype='integer' name='[Calculation_4142690391429141]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF FIRST() = 0 &#13;&#10;OR LAST() = 0&#13;&#10;THEN SUM([arrivals (unwto_processed.csv)])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
